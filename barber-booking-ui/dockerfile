# ─── STAGE 1: Build the Angular app ───
FROM node:18-alpine AS build
# Use Node.js to build — Angular CLI needs Node

WORKDIR /app
# Set working directory inside container

COPY package*.json ./
# Copy package.json and package-lock.json first
# This is a Docker best practice — if dependencies haven't changed,
# Docker uses cached layer and skips npm install (faster builds)

RUN npm ci
# Install dependencies
# 'npm ci' is used instead of 'npm install' in CI/CD
# because it's faster and uses exact versions from package-lock.json

COPY . .
# Copy rest of the source code

RUN npm run build -- --configuration production
# Build Angular app for production
# Output goes to dist/ folder

# ─── STAGE 2: Serve with Nginx ───
FROM nginx:alpine
# Fresh lightweight Nginx image
# We don't need Node anymore — this keeps image size small
# This pattern is called a "multi-stage build"

COPY --from=build /app/dist/barber-booking-ui/browser /usr/share/nginx/html
# Copy only the built files from Stage 1 into Nginx's serve directory
# Note: Angular 17+ outputs to dist/<project-name>/browser/
# For older Angular it's just dist/<project-name>/

EXPOSE 80
# Nginx serves on port 80 by default

CMD ["nginx", "-g", "daemon off;"]
# Start Nginx in foreground
# "daemon off" keeps it running in Docker (containers need a foreground process)